# Ví dụ nội dung file .env cho backend FastAPI
# (Bạn có thể copy nội dung này sang file .env trên máy của mình)

LLM_PROVIDER=openai
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL_NAME=gpt-4o-mini

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-3-small

# Ví dụ kết nối PostgreSQL (sửa lại user/password/host/dbname cho phù hợp)
DB_URL=postgresql+psycopg2://user:password@localhost:5432/chatbot_rag

VECTOR_DB_TYPE=qdrant
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_COLLECTION=documents_embeddings

DOCUMENTS_STORAGE_PATH=./storage/documents

ALLOWED_ORIGINS=http://localhost:3000

MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RAG_TOP_K=5

